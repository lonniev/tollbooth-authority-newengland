{
  "name": "Tollbooth Authority New England",
  "server": "src/tollbooth_authority/server.py",
  "deployment": {
    "env": {
      "TOLLBOOTH_NOSTR_OPERATOR_NSEC": "${TOLLBOOTH_NOSTR_OPERATOR_NSEC}",
      "NEON_DATABASE_URL": "${NEON_DATABASE_URL}",
      "CERTIFICATE_TTL_SECONDS": "600",
      "TOLLBOOTH_NOSTR_AUDIT_ENABLED": "${TOLLBOOTH_NOSTR_AUDIT_ENABLED}",
      "TOLLBOOTH_NOSTR_RELAYS": "${TOLLBOOTH_NOSTR_RELAYS}",
      "DPYC_REGISTRY_CACHE_TTL_SECONDS": "300",
      "DPYC_ENFORCE_MEMBERSHIP": "false"
    }
  }
}
